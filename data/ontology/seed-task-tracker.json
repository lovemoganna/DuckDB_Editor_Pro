  "introspections": [
    { "id": 1, "object_id": 1,  "question": "官网重构项目进度为何比计划慢了一周？",              "answer": "设计稿在首页交互细节上返工了 2 次，导致前端实现等待。另外 SEO 配置被低估，实际工作量是预估的 2 倍。", "created_at": "2024-07-10" },
    { "id": 2, "object_id": 2,  "question": "陈工同时参与 3 个项目，精力是否透支？",             "answer": "陈工在 3 个项目的工时估算之和约 40h/周，而他实际容量约 44h/周，处于临界状态。需要协调任务优先级或延期部分需求。", "created_at": "2024-08-01" },
    { "id": 3, "object_id": 10, "question": "吴总同时主管多个项目，如何保证技术质量？",           "answer": "目前主要靠周会和代码 review 两条线，但精力有限。建议给每个项目配备独立的技术负责人，吴总只做跨项目决策和关键方案评审。", "created_at": "2024-08-05" }
  ],

  "insights": [
    { "id": 1, "object_id": 1,  "insight": "前端任务的工作量评估误差率最高（平均偏差 40%），建议引入历史工时数据并增加 20% 的 Buffer",                    "tag": "估算方法",    "created_at": "2024-07-15" },
    { "id": 2, "object_id": 5,  "insight": "在多个项目间并行切换的成员，产出质量低于专注单一项目 25%，任务上下文切换成本不可忽视",                        "tag": "团队效能",    "created_at": "2024-08-01" },
    { "id": 3, "object_id": 12, "insight": "里程碑延期往往是多个任务延期累积的结果，而非单点故障。提前识别 2 周内的任务延期风险是预防里程碑延期的关键",  "tag": "项目管理",    "created_at": "2024-08-05" }
  ]
