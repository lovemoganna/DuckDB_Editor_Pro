  "insights": [
    { "id": 1, "object_id": 7,  "insight": "后端服务（后端服务）是整个风险传导网络的核心枢纽：3条「风险传导」边汇聚，2条「影响指标」边发出。确保其高可用是降低整体风险暴露的最优杠杆。",  "tag": "风险分析",  "created_at": "2025-06-01" },
    { "id": 2, "object_id": 10, "insight": "供应商A的风险传导路径最长可达4跳：供应商A断供(1)→后端服务(2)→平均恢复时间(3)→（若未修复）→系统可用性(4)。在供应商评估阶段必须将MTTR纳入合同SLA。", "tag": "风险传导",  "created_at": "2025-06-01" }
  ]
