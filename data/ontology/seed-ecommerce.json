    { "id": 1, "object_id": 13, "question": "为什么综合毛利率持续下滑？",                                  "answer": "抖音直播渠道GMV占比上升但毛利率只有18%，拉低了整体均值，同时3C数码成本上涨传导滞后。", "created_at": "2025-05-01" },
    { "id": 2, "object_id": 7,  "question": "沉睡用户的流失根因是什么？",                                  "answer": "超过60%的沉睡用户在购买后30天内没有收到任何触达，说明我们的用户生命周期运营缺失严重。", "created_at": "2025-05-03" },
    { "id": 3, "object_id": 16, "question": "新品D的高退货率（8%）背后是什么问题？",                        "answer": "详情页描述与实物存在色差，且缺少关键尺寸对比图，导致用户期望落差。",                           "created_at": "2025-05-05" }
