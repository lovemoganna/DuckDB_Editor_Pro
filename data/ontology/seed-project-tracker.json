  "introspections": [
    { "id": 1, "object_id": 7,  "question": "为什么用户中心重构进度比预期慢10%？",   "answer": "前后端联调环节沟通成本高，缺乏端到端测试环境，每次回归需要手动验证。", "created_at": "2025-05-01" },
    { "id": 2, "object_id": 13, "question": "团队速率下降的根因是什么？",             "answer": "跨团队依赖增多，代码审查队列积压，平均等待时间从2天增加到4天。",       "created_at": "2025-05-03" },
    { "id": 3, "object_id": 1,  "question": "前端团队最需要什么支持？",              "answer": "需要一个共享组件库和统一的设计规范，减少重复造轮子。",               "created_at": "2025-05-05" }
  ],

  "insights": [
    { "id": 1, "object_id": 7,  "insight": "跨团队项目需要提前锁定联调时间和环境，否则会不断延期",     "tag": "项目管理",  "created_at": "2025-05-01" },
    { "id": 2, "object_id": 14, "insight": "代码覆盖率是质量的结果，不是目标；聚焦行为测试更有效",    "tag": "质量工程",  "created_at": "2025-05-03" },
    { "id": 3, "object_id": 4,  "insight": "技术负责人的价值在于减少团队的技术债务和沟通摩擦，而非写代码", "tag": "技术领导力", "created_at": "2025-05-05" }
